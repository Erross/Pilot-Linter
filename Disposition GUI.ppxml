								<sci:legalval>Fail</sci:legalval>
								<sci:legalval>Pass</sci:legalval>
							</sci:arg>
							<sci:arg name="OnGeneralError" type="StringType" required="true" visibility="hidden" multi="false">
								<sci:legalval selected="true">Halt</sci:legalval>
								<sci:legalval>Fail</sci:legalval>
								<sci:legalval>Pass</sci:legalval>
							</sci:arg>
							<sci:arg name="CustomErrorText" type="StringType" required="false" visibility="nevershow" multi="false"/>
							<sci:arg name="ProcessingOrder" type="StringType" required="false" visibility="nevershow" multi="false">
								<sci:value>DrainTopDown</sci:value>
							</sci:arg>
							<sci:arg name="JavaClass" type="StringType" required="true" visibility="nevershow" multi="false">
								<sci:value>com.scitegic.report.component.JavaScriptComponent</sci:value>
							</sci:arg>
							<sci:arg name="CaptureStdoutStderr" type="BoolType" required="true" visibility="nevershow" multi="false">
								<sci:help>CaptureStdoutStderr</sci:help>
								<sci:legalval>True</sci:legalval>
								<sci:legalval selected="true">False</sci:legalval>
							</sci:arg>
							<sci:arg name="Registrant" type="StringType" required="false" visibility="nevershow" multi="false">
								<sci:help>The user who registered this component.</sci:help>
								<sci:value>scitegic/reportadv</sci:value>
							</sci:arg>
							<sci:arg name="RegistrationDate" type="StringType" required="false" visibility="nevershow" multi="false">
								<sci:help>The date this component was registered.</sci:help>
								<sci:value>Mon Aug 27 11:22:08 2012</sci:value>
							</sci:arg>
							<sci:arg name="ComponentDisplayName" type="StringType" required="false" visibility="nevershow" multi="false">
								<sci:value>JavaScript</sci:value>
							</sci:arg>
							<sci:arg name="ComponentPoint" type="StringType" required="false" visibility="nevershow" multi="false">
								<sci:value>90 -1895</sci:value>
							</sci:arg>
							<sci:arg name="ComponentIcon" type="StringType" required="true" visibility="nevershow" multi="false">
								<sci:value>REPORTTEXTNODE</sci:value>
							</sci:arg>
							<sci:arg name="ComponentGUID" type="StringType" required="false" visibility="nevershow" multi="false">
								<sci:value>{262A8E5D-BB8E-4dc4-A6F5-A61FC6047EC8}</sci:value>
							</sci:arg>
							<sci:arg name="DerivedFrom" type="StringType" required="false" visibility="nevershow" multi="false">
								<sci:help>The component this component is based upon.</sci:help>
								<sci:value>Plug In</sci:value>
							</sci:arg>
							<sci:arg name="ComponentDisabled" type="LongType" required="false" visibility="nevershow" multi="false">
								<sci:value>0</sci:value>
							</sci:arg>
							<sci:arg name="ComponentHelp" type="StringType" required="false" visibility="nevershow" multi="true">
								<sci:value>100</sci:value>
								<sci:value>Adds JavaScript to an HTML Report</sci:value>
								<sci:value>&lt;p&gt;Type the JavaScript into &lt;i&gt;Script&lt;/i&gt;.  The script will be included in either the header or body of the HTML report, depending on &lt;i&gt;Output Location&lt;/i&gt;.  Functions defined in the script are accessible using &lt;i&gt;HTML Attributes&lt;/i&gt;, which is present in many Reporting Collection components.&lt;/p&gt;

&lt;p&gt;
Pipeline Pilot Globals may be used in JavaScript as shown in the following example:
&lt;/p&gt;
&lt;pre style=&quot;font-family: monospace; font-size: 11px;&quot;&gt;
function showUserName() {
  alert(&apos;$(UserName)&apos;);
}
&lt;/pre&gt;
&lt;p&gt;
Calling the &lt;code&gt;showUserName&lt;/code&gt; function will show an alert window containing the name of the user that ran the protocol.
&lt;/p&gt;

&lt;p&gt;Not valid for PDF reports.&lt;/p&gt;

&lt;p&gt;&lt;b&gt;See Also:&lt;/b&gt;&lt;/p&gt;

&lt;ul&gt;
	&lt;li&gt;&lt;a href=&quot;javascript:DoLink(&apos;sciapps/scitegic/report/docs/reporting_basic.pdf&apos;)&quot;&gt;Report Design Essentials&lt;/a&gt;&lt;/li&gt;
	&lt;li&gt;&lt;a href=&quot;javascript:DoLink(&apos;sciapps/scitegic/reportadv/docs/reportadv_interactive.pdf&apos;)&quot;&gt;Interactive Reporting and Form Design&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;
</sci:value>
								<sci:value>None</sci:value>
								<sci:value/>
								<sci:value>Generic</sci:value>
								<sci:value>A single data record containing the JavaScript to be included in the HTML report.</sci:value>
								<sci:value>None</sci:value>
								<sci:value/>
							</sci:arg>
							<sci:arg name="Component Sticky Notes" type="StringType" required="false" visibility="nevershow" multi="false"/>
							<sci:arg name="RegistrationVersion" type="StringType" required="false" visibility="nevershow" multi="false">
								<sci:help>The server version when this component was registered</sci:help>
								<sci:value>9.0.0.7</sci:value>
							</sci:arg>
							<sci:arg name="Use Package" type="StringType" required="false" visibility="nevershow" multi="true">
								<sci:value>scitegic/report</sci:value>
							</sci:arg>
							<sci:arg name="ComponentLocalID" type="LongType" required="false" visibility="nevershow" multi="false">
								<sci:help>Local Component Identifier</sci:help>
								<sci:value>10</sci:value>
							</sci:arg>
							<sci:arg name="Component Path" type="StringType" required="false" visibility="nevershow" multi="false">
								<sci:help>The original path within the database of this component.</sci:help>
								<sci:value>Components\Reporting and Visualization\Reporting\Web Application Development\JavaScript Elements\JavaScript</sci:value>
							</sci:arg>
						</sci:component>
					</sci:data>
					<sci:data object="SciTegic.ComponentJavaPlugin.1">
						<sci:component name="Protocol Function" version="2">
							<sci:arg name="Function Name" type="StringType" required="true" visibility="visible" multi="false">
								<sci:help>&lt;p&gt;The name of the generated JavaScript function. This is the function you will call on another reporting component when the user performs some action (e.g., submitting a form or clicking on a link). The arguments that need to be passed to the function depend on the &lt;i&gt;Function Arguments&lt;/i&gt; and &lt;i&gt;When Protocol Finishes&lt;/i&gt; parameters &amp;mdash; see their parameter help for more information.&lt;/p&gt;
</sci:help>
								<sci:value>sendUDCodeToWorker</sci:value>
							</sci:arg>
							<sci:arg name="Protocol" type="ProtocolFunctionType" required="true" visibility="visible" multi="false">
								<sci:help>&lt;p&gt;Path to the protocol that will be run when the function is called. Editing this parameter opens up the Protocol Function Dialog.&lt;/p&gt;</sci:help>
								<sci:value>500</sci:value>
								<sci:value>{2DEF82CD-B9FB-4605-9C52-E687BB8D7A7C}</sci:value>
								<sci:value>False</sci:value>
								<sci:value>UGxlYXNlIHdhaXQgd2hpbGUgdGhlIGRvY3VtZW50IGxvYWRz</sci:value>
								<sci:value>Current</sci:value>
								<sci:value>JsonInput</sci:value>
								<sci:value>&apos;&apos;{&quot;Taskplan&quot;:&quot;00d1dce4-1c5b-497e-af9f-640f3fea96a9&quot;,&quot;SelectedOption&quot;:&quot;Nonconforming for attribute test&quot;}&apos;&apos;</sci:value>
							</sci:arg>
							<sci:arg name="Function Arguments" type="StringType" required="false" visibility="visible" multi="false">
								<sci:help>&lt;p&gt;Determines how the parameters to be passed to the executed protocol should be passed to the generated JavaScript function. Possible values are:&lt;/p&gt;

&lt;ul&gt;
	&lt;li&gt;
		&lt;p&gt;&lt;i&gt;Protocol-level Parameters&lt;/i&gt;: The generated function will expect a separate value to be passed in for each of the protocol-level parameters on the target protocol. For example, the &lt;a href=&quot;javascript:DoLink(&apos;{B0D221A3-F8B0-464B-B520-EDC88584514E}&apos;)&quot;&gt;Update Chart Axis&lt;/a&gt; utility protocol, which is used by the &lt;a href=&quot;javascript:DoLink(&apos;{C1959C9B-F218-4FF5-968E-FE6E47970FB5}&apos;)&quot;&gt;Update Chart Axis via Callback Function&lt;/a&gt; example, defines &lt;i&gt;X Axis Minimum&lt;/i&gt;, &lt;i&gt;X Axis Maximum&lt;/i&gt;, and &lt;i&gt;Destination&lt;/i&gt; parameters. The prototype for the generated function is:&lt;/p&gt;
		&lt;p&gt;&lt;code&gt;function updateChartAxis(X_Axis_Minimum, X_Axis_Maximum, Destination, callback, callbackData, failureCallback);&lt;/code&gt;&lt;/p&gt;
		&lt;p&gt;Note that presence of the &lt;i&gt;callback&lt;/i&gt; and &lt;i&gt;callbackData&lt;/i&gt; arguments is determined by the &lt;i&gt;When Protocol Finishes&lt;/i&gt; parameter, which is in this case set to &quot;Call User-supplied JavaScript Callback&quot;.&lt;/p&gt;
	&lt;/li&gt;
	&lt;li&gt;
		&lt;p&gt;&lt;i&gt;JavaScript Object (Name-Value Map)&lt;/i&gt;: The generated function will expect a single JavaScript object to be passed in that will define a mapping from protocol parameter names to values. The function prototype is always the same regardless of the target protocol:&lt;/p&gt;
		&lt;p&gt;&lt;code&gt;function updateChartAxis(argumentMap, callback, callbackData, failureCallback)&lt;/code&gt;&lt;/p&gt;
		&lt;p&gt;To create an object that would define parameters for the protocol described above, you could use:&lt;/p&gt;
		&lt;p&gt;&lt;code&gt;var updateChartArgs = {
  &apos;X Axis Minimum&apos;: -8,
  &apos;X Axis Maximum&apos;: -4,
  &apos;Destination&apos;: &apos;./XYPlot.png&apos;
};&lt;/code&gt;&lt;/p&gt;
&lt;/ul&gt;</sci:help>
								<sci:legalval>Protocol-level Parameters</sci:legalval>
								<sci:legalval selected="true">JavaScript Object (Name-Value Map)</sci:legalval>
							</sci:arg>
							<sci:arg name="When Protocol Finishes" type="StringType" required="false" visibility="visible" multi="false" expanded="true">
								<sci:help>&lt;p&gt;The way in which the protocol results are to be handled:&lt;/p&gt;

&lt;ul&gt;
	&lt;li&gt;
		&lt;p&gt;&lt;i&gt;Call User-supplied Javascript Callback&lt;/i&gt;: The last arguments passed to the JavaScript function created by this component are a user-defined function which will be called when the protocol results are available, a data object to be passed to that function, and a user-defined function to be called if protocol execution fails. For example, the &lt;a href=&quot;javascript:DoLink(&apos;{B0D221A3-F8B0-464B-B520-EDC88584514E}&apos;)&quot;&gt;Update Chart Axis&lt;/a&gt; utility protocol, which is used by the &lt;a href=&quot;javascript:DoLink(&apos;{C1959C9B-F218-4FF5-968E-FE6E47970FB5}&apos;)&quot;&gt;Update Chart Axis via Callback Function&lt;/a&gt; example, defines &lt;i&gt;X Axis Minimum&lt;/i&gt;, &lt;i&gt;X Axis Maximum&lt;/i&gt;, and &lt;i&gt;Destination&lt;/i&gt; parameters. The prototype for the generated function is:&lt;/p&gt;
		&lt;p&gt;&lt;code&gt;function updateChartAxis(X_Axis_Minimum, X_Axis_Maximum, Destination, callback, callbackData, failureCallback);&lt;/code&gt;&lt;/p&gt;
		&lt;p&gt;A callback value must be specified and must be of type function. The callbackData and failureCallback arguments are optional.&lt;/p&gt;
		&lt;p&gt;The failureCallback argument can be used to provide a JavaScript function to be called if protocol execution fails, or if authentication is required and is cancelled by the user. The default behavior if this parameter is left blank is to pop up a browser alert window with the error message from the protocol. The arguments to the function will be (1) the error message from the protocol or &quot;Authentication Cancelled&quot;, if that is the cause of the failure, and (2) the callback data passed into the protocol function, if specified.&lt;/p&gt;
		&lt;p&gt;&lt;i&gt;Put Output in Dynamic Content Container&lt;/i&gt;: The contents of the result files will be inserted into the &lt;a href=&quot;javascript:DoLink(&apos;{557CDA43-AC9E-44BC-AB02-FD126CC82B7C}&apos;)&quot;&gt;Dynamic Content Container&lt;/a&gt;s or &lt;a href=&quot;javascript:DoLink(&apos;{6FBAE9E7-2825-4C1B-865E-723D10C0E04B}&apos;)&quot;&gt;Tab&lt;/a&gt;s in the current report with IDs that match &lt;i&gt;Dynamic Content Container ID&lt;/i&gt;.&lt;/p&gt;
	&lt;/li&gt;
&lt;/ul&gt;
</sci:help>
								<sci:member>Callback Function Gets</sci:member>
								<sci:member>Dynamic Content Container ID</sci:member>
								<sci:legalval>Call User-supplied JavaScript Callback</sci:legalval>
								<sci:legalval selected="true">Put Output in Dynamic Content Container</sci:legalval>
							</sci:arg>
							<sci:arg name="Callback Function Gets" type="StringType" required="false" visibility="visible" multi="false">
								<sci:help>&lt;p&gt;Determines how the protocol&apos;s results are passed to the user-defined callback function that is called when the results are available (i.e., the protocol that is called by the JavaScript function returns). Use &lt;b&gt;First Result File&lt;/b&gt; to receive the contents of the first result file. Use &lt;b&gt;List of Result File URIs&lt;/b&gt; to receive an array of result file URIs. Use &lt;b&gt;Result Properties (as JavaScript Object)&lt;/b&gt; to receive a single JavaScript object containing the result properties from the protocol  (as specified in the &lt;i&gt;Web Services&lt;/i&gt; tab of that protocol). Your callback function will receive the callback data you passed to the protocol function as its second argument.&lt;/p&gt;

&lt;p&gt;You can use the &lt;i&gt;getFileAsText(uri, callback, callbackData)&lt;/i&gt; utility function to download the contents of a URI into a string. It takes the URI of a file to download, the name of a function to call when the downloading completes, and data to pass to that function. That callback function will be invoked with the file contents and callback data. The &lt;i&gt;getFileAsText()&lt;/i&gt; utility function is defined in the protocolFunction.js JavaScript file and is automatically available whenever you use a protocol function component. This function will work in the SharePoint environment by using the JavaScript SDK&apos;s proxy applet to circumvent the browser&apos;s cross site scripting restrictions. Complex Pipeline Pilot reports fetched this way may not work when dynamically inserted into SharePoint pages, because the SharePoint Bridge will not get a chance to intercept and post-process the content.&lt;/p&gt;</sci:help>
								<sci:enabledscript>RMATCH(PARAMETER(&apos;When Protocol Finishes&apos;), &apos;callback&apos;, &apos;i&apos;)</sci:enabledscript>
								<sci:legalval>First Result File</sci:legalval>
								<sci:legalval>List of Result File URIs</sci:legalval>
								<sci:legalval selected="true">Result Properties (as JavaScript Object)</sci:legalval>
							</sci:arg>
							<sci:arg name="Dynamic Content Container ID" type="StringType" required="false" visibility="visible" multi="false">
								<sci:help>&lt;p&gt;The ID of one or more &lt;a href=&quot;javascript:DoLink(&apos;{557CDA43-AC9E-44BC-AB02-FD126CC82B7C}&apos;)&quot;&gt;Dynamic Content Container&lt;/a&gt;s or &lt;a href=&quot;javascript:DoLink(&apos;{6FBAE9E7-2825-4C1B-865E-723D10C0E04B}&apos;)&quot;&gt;Tab&lt;/a&gt;s into which the contents of result files should be inserted. Tab IDs are specified in the form &quot;&amp;lt;Tab Group ID&amp;gt;/&amp;lt;Tab Title&amp;gt;&quot;. Multiple IDs should be separated with commas. The contents of the n&apos;th result file will be inserted into the n&apos;th container. If the result file suffix is .htm or .html, the contents of the file will be directly inserted into the current document. If the result file suffix is .png, .gif, or .jpg, an image reference will be generated.&lt;/p&gt;

&lt;p&gt;If this parameter is left blank but &lt;i&gt;When Protocol Finishes&lt;/i&gt; is set to &quot;Put Output in Dynamic Content Container&quot;, then an additional &lt;i&gt;containerIds&lt;/i&gt; argument will be added to the protocol function after the parameter arguments. JavaScript functions that call the protocol function can make use of this to dynamically set the container to insert content into, or to create a sequence of new tabs.&lt;/p&gt;</sci:help>
								<sci:enabledscript>RMATCH(PARAMETER(&apos;When Protocol Finishes&apos;), &apos;dynamic content&apos;, &apos;i&apos;)</sci:enabledscript>
								<sci:value>ReportContainer</sci:value>
							</sci:arg>
							<sci:arg name="When Running Protocol" type="StringType" required="false" visibility="visible" multi="false">
								<sci:help>&lt;p&gt;Determines the visual feedback when the protocol function is activated. Possible values are:&lt;/p&gt;

&lt;ul&gt;
	&lt;li&gt;&lt;i&gt;Show Busy Cursor&lt;/i&gt;: A busy cursor (typically an hourglass) will be displayed while the protocol runs. This will prevent users from performing other actions in the report until the called protocol is finished.&lt;/li&gt;
	&lt;li&gt;&lt;i&gt;Dim Screen and Show Loading Message&lt;/i&gt;: The currently displayed report is dimmed and a prominent &quot;Loading ...&quot; message is displayed in the center of the screen. The busy cursor is also displayed.&lt;/li&gt;
	&lt;li&gt;&lt;i&gt;Show Loading Message in Containers&lt;/i&gt;: A &quot;Loading ...&quot; message will be displayed in any containers identified as recieving protocol output. The busy cursor is also displayed. This is only available when &lt;i&gt;When Protocol Finishes&lt;/i&gt; is equal to &quot;Put output in dynamic content container&quot;.&lt;/li&gt;
	&lt;li&gt;&lt;i&gt;Do Nothing&lt;/i&gt;&lt;/li&gt;
&lt;/ul&gt;

&lt;p&gt;&lt;b&gt;Notes:&lt;/b&gt;&lt;/p&gt;

&lt;ul&gt;
	&lt;li&gt;Screen dimming and loading messages work by overlaying temporary HTML content over the browser window. Unfortunately active content such as Java will remain visible above the overlay, so the success of these techniques is dependent on other report content.&lt;/li&gt;
&lt;/ul&gt;
</sci:help>
								<sci:legalvalscript>Resize(#lvals, 0);
Append(#lvals, &apos;Show Busy Cursor&apos;);
Append(#lvals, &apos;Dim Screen and Show Loading Message&apos;);
IF Parameter(&apos;When Protocol Finishes&apos;) EQ &apos;Put Output in Dynamic Content Container&apos; THEN
	Append(#lvals, &apos;Show Loading Message in Containers&apos;);
END IF;
Append(#lvals, &apos;Do Nothing&apos;);
SetLegalValues(#lvals);</sci:legalvalscript>
								<sci:value>Dim Screen and Show Loading Message</sci:value>
							</sci:arg>
							<sci:arg name="Additional Options" type="GroupType" required="false" visibility="visible" multi="false" expanded="true">
								<sci:help>&lt;p&gt;Parameters configuring complex component behavior. These wil typically not need to be modified.&lt;/p&gt;</sci:help>
								<sci:member>Application ID</sci:member>
							</sci:arg>
							<sci:arg name="Application ID" type="StringType" required="false" visibility="visible" multi="false">
								<sci:help>&lt;p&gt;Optimize server performance by specifying how processes on the Pipeline Pilot server may be re-used to run multiple protocols sequentially. A protocol launched with an application ID will re-use a Pipeline Pilot server process with the same application ID, if one is available, significantly reducing protocol startup overhead. This is particularly important for short-running protocols (less than five seconds).&lt;/p&gt;

&lt;p&gt;The default value of &quot;$(RunId)&quot; allows re-use of server processes between jobs launched from a single report, and will generally be the appropriate choice. However, if your report contains multiple pages joined by hyperlinks or forms, or multiple levels of nested dynamic content, you may gain increased performance by providing a fixed &lt;em&gt;Application ID&lt;/em&gt; value to be shared by all protocol functions across the application.  The value you provide should just be a simple string, for example the name of the application&apos;s entry protocol, and by using this for all Protocol Functions in your application, you increase the likelihood there will be an existing process to use whenever a protocol is executed.&lt;/p&gt;

&lt;p&gt;In some rare cases, re-using server processes may lead to problems with data or state being transferred between jobs. For example, this has been observed with the Perl on Server component, which does not fully re-set its environment when run multiple times. When this happens, clearing the &lt;em&gt;Application ID&lt;/em&gt; (i.e., providing not value) should ensure that server processes are never re-used, and each new protocol launched will have its own process.&lt;/p&gt;

&lt;p&gt;The behavior described above is affected by both settings in the administration portal and the system of authentication used on the Pipeline Pilot server. If no-op protocols are not running in fractions of a second, your may wish to contact your server administrator to see whether these features are enabled.&lt;/p&gt;

</sci:help>
								<sci:value>$(RunId)</sci:value>
							</sci:arg>
							<sci:arg name="ComponentAttributes" type="StringType" required="false" visibility="hidden" multi="true" expanded="true">
								<sci:help>Component Attributes</sci:help>
								<sci:legalval>ComponentTakesInput</sci:legalval>
								<sci:legalval selected="true">ComponentReturnsPass</sci:legalval>
								<sci:legalval>ComponentReturnsFail</sci:legalval>
								<sci:legalval>ComponentRunsLocal</sci:legalval>
							</sci:arg>
							<sci:arg name="OnDataTypeError" type="StringType" required="true" visibility="hidden" multi="false" expanded="true">
								<sci:legalval selected="true">Halt</sci:legalval>
								<sci:legalval>Fail</sci:legalval>
								<sci:legalval>Pass</sci:legalval>
							</sci:arg>
							<sci:arg name="OnGeneralError" type="StringType" required="true" visibility="hidden" multi="false" expanded="true">
								<sci:legalval selected="true">Halt</sci:legalval>
								<sci:legalval>Fail</sci:legalval>
								<sci:legalval>Pass</sci:legalval>
							</sci:arg>
							<sci:arg name="CustomErrorText" type="StringType" required="false" visibility="nevershow" multi="false" expanded="true"/>
							<sci:arg name="JavaClass" type="StringType" required="true" visibility="nevershow" multi="false" expanded="true">
								<sci:value>com.scitegic.report.component.ProtocolFunctionComponent</sci:value>
							</sci:arg>
							<sci:arg name="ProcessingOrder" type="StringType" required="false" visibility="nevershow" multi="false" expanded="true">
								<sci:value>DrainTopDown</sci:value>
							</sci:arg>
							<sci:arg name="CaptureStdoutStderr" type="BoolType" required="true" visibility="nevershow" multi="false" expanded="true">
								<sci:help>CaptureStdoutStderr</sci:help>
								<sci:legalval>True</sci:legalval>
								<sci:legalval selected="true">False</sci:legalval>
							</sci:arg>
							<sci:arg name="Registrant" type="StringType" required="false" visibility="nevershow" multi="false" expanded="true">
								<sci:help>The user who registered this component.</sci:help>
								<sci:value>scitegic/reportadv</sci:value>
							</sci:arg>
							<sci:arg name="RegistrationDate" type="StringType" required="false" visibility="nevershow" multi="false" expanded="true">
								<sci:help>The date this component was registered.</sci:help>
								<sci:value>Mon Oct 10 13:36:12 2011</sci:value>
							</sci:arg>
							<sci:arg name="ComponentDisplayName" type="StringType" required="false" visibility="nevershow" multi="false" expanded="true">
								<sci:value>Protocol Function 
for sendDataToProductInformationReportProtocol</sci:value>
							</sci:arg>
							<sci:arg name="ComponentPoint" type="StringType" required="false" visibility="nevershow" multi="false" expanded="true">
								<sci:value>90 -2255</sci:value>
							</sci:arg>
							<sci:arg name="ComponentIcon" type="StringType" required="true" visibility="nevershow" multi="false" expanded="true">
								<sci:value>REPORTTEXTNODE</sci:value>
							</sci:arg>
							<sci:arg name="ComponentGUID" type="StringType" required="false" visibility="nevershow" multi="false" expanded="true">
								<sci:value>{5D0F8E8E-290C-4e9c-81D1-223ACA806544}</sci:value>
							</sci:arg>
							<sci:arg name="DerivedFrom" type="StringType" required="false" visibility="nevershow" multi="false" expanded="true">
								<sci:help>The component this component is based upon.</sci:help>
								<sci:value>Plug In</sci:value>
							</sci:arg>
							<sci:arg name="ComponentDisabled" type="LongType" required="false" visibility="nevershow" multi="false" expanded="true">
								<sci:value>0</sci:value>
							</sci:arg>
							<sci:arg name="ComponentHelp" type="StringType" required="false" visibility="nevershow" multi="true" expanded="true">
								<sci:value>100</sci:value>
								<sci:value>Outputs a JavaScript function that runs a protocol for dynamic (AJAX-style) reports</sci:value>
								<sci:value>&lt;p&gt;Use this component to link to a protocol, the results of which can be added to the current report without having to redraw the whole page, in the style of &lt;a href=&quot;javascript:DoLink(&apos;http://en.wikipedia.org/wiki/AJAX&apos;)&quot;&gt;AJAX&lt;/a&gt;.

&lt;p&gt;To use the Protocol Function component you need three elements in the protocol:&lt;/p&gt;

&lt;ol&gt;
	&lt;li&gt;A Protocol Function component to add a JavaScript function to the current report that will execute the specified protocol when executed.&lt;/li&gt;
	&lt;li&gt;A reporting element with an event handler that calls the JavaScript function. Event handlers are usually defined using the &lt;i&gt;HTML Attributes&lt;/i&gt; parameter on a component, with a value like &lt;code&gt;onclick = protocolFunctionName()&lt;/code&gt;. More on this below.&lt;/li&gt;
	&lt;li&gt;A &lt;a href=&quot;javascript:DoLink(&apos;{557CDA43-AC9E-44BC-AB02-FD126CC82B7C}&apos;)&quot;&gt;Dynamic Content Container&lt;/a&gt; or &lt;a href=&quot;javascript:DoLink(&apos;{6FBAE9E7-2825-4C1B-865E-723D10C0E04B}&apos;)&quot;&gt;Tab&lt;/a&gt; to place the generated content into, or a &lt;a href=&quot;javascript:DoLink(&apos;{262A8E5D-BB8E-4dc4-A6F5-A61FC6047EC8}&apos;)&quot;&gt;JavaScript&lt;/a&gt; or &lt;a href=&quot;javascript:DoLink(&apos;{6DF7D4FA-28BC-453b-8882-DE55C7CFFBF9}&apos;)&quot;&gt;Include&lt;/a&gt; component defining a callback function to be executed when the protocol returns.&lt;/li&gt;
&lt;/ol&gt;

&lt;p&gt;&lt;b&gt;Calling A Protocol Function&lt;/b&gt;&lt;/p&gt;

&lt;p&gt;The JavaScript function generated by the Protocol Function component takes as arguments either the values to be passed to each protocol-level parameter defined on the target protocol or a single JavaScript object providing a mapping of parameter names to values, a callback function to be executed when the target protocol completes, and optionally a callback data object which will be passed to that function. If dynamic content containers or tabs are being used, the callback function parameter doesn&apos;t need to be specified. The parameter list on the generated function is determined when the original report is generated &amp;mdash; if the target protocol&apos;s parameter list is modified, then any reports with generated functions that enumerate the parameter list on that protocol will have to be regenerated.&lt;/p&gt;

&lt;p&gt;A call to a JavaScript function is often defined in the &lt;i&gt;HTML Attributes&lt;/i&gt; parameter on a Submit Button. To do this, open the HTML Attributes dialog and set the Name to &lt;b&gt;onclick&lt;/b&gt; and Value to &lt;b&gt;&quot;protocolFunctionName(&apos;parameter1&apos;, &apos;parameter2&apos;);&quot;&lt;/b&gt;, where in this case there are two parameters.  If there are no parameters, simply provide the opening and closing parentheses.  Parameters should always be single-quoted, and you can use string-token replacement to provide global variables.&lt;/p&gt;

&lt;p&gt;The easiest way to pass values entered in textboxes or selected from lists to the target protocol is to define a JavaScript function to fetch those values and pass them to the protocol function. By defining a unique ID (again using &lt;i&gt;HTML Attributes&lt;/i&gt; on each form element), it should be possible to use &lt;code&gt;document.getElementById(&quot;id&quot;).value&lt;/code&gt; to obtain the value of that form element in JavaScript. See the &lt;a href=&quot;javascript:DoLink(&apos;{921AFE72-0F37-4707-81A5-B252664A0C14}&apos;)&quot;&gt;Update Chart Axis via Dynamic Content Container&lt;/a&gt; and &lt;a href=&quot;javascript:DoLink(&apos;{C1959C9B-F218-4FF5-968E-FE6E47970FB5}&apos;)&quot;&gt;Update Chart Axis via Callback Function&lt;/a&gt; examples to see how to do this.&lt;/p&gt;

&lt;p&gt;&lt;b&gt;Putting Content in a Dynamic Content Container&lt;/b&gt;&lt;/p&gt;

&lt;p&gt;This is the simplest way to add AJAX-style functionality to reports. Set &lt;i&gt;When Protocol Finishes&lt;/i&gt; to &quot;Put Output in Dynamic Content Container&quot; and set &lt;i&gt;Dynamic Content Container ID&lt;/i&gt; equal to the IDs of one or more &lt;a href=&quot;javascript:DoLink(&apos;{557CDA43-AC9E-44BC-AB02-FD126CC82B7C}&apos;)&quot;&gt;Dynamic Content Container&lt;/a&gt;s included in this report. The contents of the n&apos;th result file will be automatically inserted into the n&apos;th container. If the result file suffix is .htm or .html, the contents of the file will be inserted into the current document. If the result file suffix is .png, .gif, or .jpg, an image reference will be generated.&lt;/p&gt;

&lt;p&gt;When &lt;i&gt;When Protocol Finishes&lt;/i&gt; is set to &quot;Put Output in Dynamic Content Container&quot;, the JavaScript function generated sends an additional parameter (&quot;Generate AJAX Content&quot;=true) to the target protocol that causes all HTML Report Viewers and Writers in the protocol to generate HTML fragments that can be dynamically inserted into another HTML document. The way that JavaScript is included and startup functions are called is modified so that it will work in this environment.&lt;/p&gt;

&lt;p&gt;&lt;b&gt;Putting Content in a Tab&lt;/b&gt;&lt;/p&gt;

&lt;p&gt;Reports generated by helper protocols can be inserted directly into existing or new &lt;a href=&quot;javascript:DoLink(&apos;{6FBAE9E7-2825-4C1B-865E-723D10C0E04B}&apos;)&quot;&gt;Tab&lt;/a&gt;s by setting &lt;i&gt;When Protocol Finishes&lt;/i&gt; to &quot;Put Output in Dynamic Content Container&quot;. Then set the &lt;i&gt;Dynamic Content Container ID&lt;/i&gt; to the IDs of one or more tabs, in the form &quot;&amp;lt;Tab Group ID&amp;gt;/&amp;lt;Tab Title&amp;gt;&quot;. The Tab Group ID should correspond to an &quot;id&quot; HTML attribute on a &lt;a href=&quot;javascript:DoLink(&apos;{00D97472-FA8F-41A8-9841-095DBCB3F989}&apos;)&quot;&gt;Tab Group&lt;/a&gt; in the current protocol. If the Tab Title matches an existing tab, its content will be overwritten, and the tab activated. If no tab with a matching Tab Title exists, a new tab will be generated, and activated. When a protocol function inserts content into multiple existing tabs, the active tab is not changed.&lt;/p&gt;

&lt;p&gt;See the &lt;a href=&quot;javascript:DoLink(&apos;{D33E846F-EBBD-4B58-8AA8-6B3EB226EF2A}&apos;)&quot;&gt;Car Finder&lt;/a&gt; example to see how to use Protocol Functions and Tabs.&lt;/p&gt;

&lt;p&gt;&lt;b&gt;Passing Content to a User Defined Callback Function&lt;/b&gt;&lt;/p&gt;

&lt;p&gt;If the protocol provides data rather than reporting elements, a user-defined JavaScript function can be used to generate reporting content dynamically. Set &lt;i&gt;When Protocol Finishes&lt;/i&gt; to &quot;Call User-supplied JavaScript callback&quot; and provide the name of the callback as the last argument when calling the protocol function. The callback will receive either the contents of the first result file or the list of result file URIs, depending on the value of &lt;i&gt;Callback Function Gets&lt;/i&gt;.&lt;/p&gt;

&lt;p&gt;When the result of a protocol is data to be manipulated by a user callback, that protocol should use a &lt;a href=&quot;javascript:DoLink(&apos;{12FAD7B3-EF3C-41c1-9259-C3DE6C056CC8}&apos;)&quot;&gt;JSON Writer&lt;/a&gt; to output a series of data records as JavaScript data. These can be converted directly to a JavaScript object in the result-processing callback using the &lt;i&gt;eval()&lt;/i&gt; function, and then iterated over to generate a table or other HTML reporting elements.&lt;/p&gt;

&lt;p&gt;&lt;b&gt;Notes&lt;/b&gt;&lt;/p&gt;

&lt;ul&gt;
	&lt;li&gt;This component is for use in HTML reports only.&lt;/li&gt;
	&lt;li&gt;Protocol Function components should have unique &lt;i&gt;Function Name&lt;/i&gt; values.&lt;/li&gt;
	&lt;li&gt;The result files will be available for at least one minute, but any files in the job directory may be deleted after that when the job&apos;s resources are released. For this reason, it is not appropriate to provide hyperlinks to result files in the job directory.&lt;/li&gt;
	&lt;li&gt;Users are authenticated when they first execute the protocol function using their single sign on cookie. If they do not yet have a cookie, they will be asked to authenticate in a pop-up dialog.&lt;/li&gt;
&lt;/ul&gt;

&lt;p&gt;&lt;b&gt;See Also:&lt;/b&gt;&lt;/p&gt;

&lt;ul&gt;
	&lt;li&gt;&lt;a href=&quot;javascript:DoLink(&apos;sciapps/scitegic/report/docs/reporting_basic.pdf&apos;)&quot;&gt;Report Design Essentials&lt;/a&gt;&lt;/li&gt;
	&lt;li&gt;&lt;a href=&quot;javascript:DoLink(&apos;sciapps/scitegic/reportadv/docs/reportadv_interactive.pdf&apos;)&quot;&gt;Interactive Reporting and Form Design&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;
</sci:value>
