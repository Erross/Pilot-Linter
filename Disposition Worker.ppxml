						<sci:legalval>studies</sci:legalval>
						<sci:legalval>studycandidates</sci:legalval>
						<sci:legalval>studyparameters</sci:legalval>
						<sci:legalval>tags</sci:legalval>
						<sci:legalval selected="true">tasks</sci:legalval>
						<sci:legalval>taskparameters</sci:legalval>
						<sci:legalval>taskprotocols</sci:legalval>
						<sci:legalval>taskrelationships</sci:legalval>
