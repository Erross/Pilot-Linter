ses,/watchers,/watchers/{id},/widgets,/widgets/{id},/widgets/{id}/groups,/widgets/{id}/widgetcolumns,/widgets/{id}/widgetfilters,/widgets/{id}/widgetviews,/widgetfilters,/widgetfilters/{id},/widgetviews,/widgetviews/{id}</sci:propval>
