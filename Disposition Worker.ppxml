					</sci:arg>
					<sci:arg name="Endpoint" type="StringType" required="true" visibility="visible" multi="false" expanded="true">
						<sci:metaproplist>
							<sci:mpropval name="SCI_PromotedFrom" type="StringType">
								<sci:value>Endpoint</sci:value>
							</sci:mpropval>
							<sci:propval name="SCI_PromotionRenameRule">UsingParent</sci:propval>
						</sci:metaproplist>
						<sci:help>Endpoints associated with specified entity</sci:help>
						<sci:member>Custom Endpoint</sci:member>
						<sci:legalvalscript>endpoints := Parameter(&apos;Endpoints&apos;);
Expand(&apos;,&apos;,EndPoints);
entity := Parameter(&apos;Entity&apos;);
ForEach endpoint in endpoints loop
if endpoint rlike &apos;^\/&apos;.entity.&apos;\/&apos; or endpoint rlike &apos;^\/&apos;.entity.&apos;$&apos; then
Append(lvals,endpoint);
end if;
end loop;
if Trim(Parameter(&apos;Entity&apos;)) ne &apos;&apos; then
	Append(lvals,&apos;custom&apos;);
end if;
SetLegalValues(lvals);</sci:legalvalscript>
						<sci:value>/runsets/{id}</sci:value>
					</sci:arg>
					<sci:arg name="Custom Endpoint" type="StringType" required="false" visibility="visible" multi="false">
						<sci:metaproplist>
							<sci:mpropval name="SCI_PromotedFrom" type="StringType">
								<sci:value>Custom Endpoint</sci:value>
							</sci:mpropval>
							<sci:propval name="SCI_PromotionRenameRule">UsingParent</sci:propval>
						</sci:metaproplist>
						<sci:validscript>SetInvalidDetails(ParameterName() . &apos; must be begin with &apos; . &apos;/&apos;. Parameter(&apos;Entity&apos;));
FindSubString(Parameter(),&apos;/&apos;.Parameter(&apos;Entity&apos;)) &gt; 0</sci:validscript>
						<sci:enabledscript>Parameter(&apos;Endpoint&apos;) eq &apos;Custom&apos;;</sci:enabledscript>
					</sci:arg>
					<sci:arg name="Id" type="StringType" required="true" visibility="visible" multi="false">
						<sci:metaproplist>
							<sci:mpropval name="SCI_PromotedFrom" type="StringType">
								<sci:value>Id</sci:value>
							</sci:mpropval>
							<sci:propval name="SCI_PromotionRenameRule">UsingParent</sci:propval>
						</sci:metaproplist>
						<sci:help>Id associated with specified entity</sci:help>
						<sci:enabledscript>Parameter(&apos;Endpoint&apos;) rlike &apos;{id}&apos; or
(Parameter(&apos;Endpoint&apos;) eq &apos;custom&apos; 
	and Parameter(&apos;Custom Endpoint&apos;) rlike &apos;{id}&apos;)</sci:enabledscript>
						<sci:value>$(TaskPlanGUID)</sci:value>
					</sci:arg>
					<sci:arg name="Group Modifiers" type="StringType" required="false" visibility="visible" multi="false" expanded="true">
						<sci:metaproplist>
							<sci:mpropval name="SCI_PromotedFrom" type="StringType">
								<sci:value>Group Modifiers</sci:value>
							</sci:mpropval>
							<sci:propval name="SCI_PromotionRenameRule">UsingParent</sci:propval>
						</sci:metaproplist>
						<sci:help>
&lt;p&gt;Modifies data records from the Hub using the set of APIs. The modifiers are detailed in the following link:&lt;/p&gt;
&lt;p&gt;&lt;a href=&quot;javascript:DoLink(&apos;https://lw5-ttr1-bio.dsone.3ds.com:8443/foundation/hub/doc/odata&apos;)&quot;&gt;OData Specifications&lt;/a&gt;&lt;/p&gt;
</sci:help>
						<sci:member>Count</sci:member>
						<sci:member>Distinct</sci:member>
						<sci:member>Filter</sci:member>
						<sci:member>Order By</sci:member>
						<sci:member>Page</sci:member>
						<sci:member>Search</sci:member>
						<sci:member>Show</sci:member>
						<sci:member>Skip</sci:member>
						<sci:member>Top</sci:member>
						<sci:member>Version</sci:member>
						<sci:enabledscript>Parameter(&apos;Endpoint&apos;) not rlike &apos;/{id}$&apos;;</sci:enabledscript>
					</sci:arg>
					<sci:arg name="Count" type="BoolType" required="false" visibility="visible" multi="false">
						<sci:metaproplist>
							<sci:mpropval name="SCI_PromotedFrom" type="StringType">
								<sci:value>Count</sci:value>
							</sci:mpropval>
						</sci:metaproplist>
						<sci:help>&lt;p&gt;The &lt;b&gt;count&lt;/b&gt; query option can be used to include the total records with the collection of resources that is returned. 
This query option is only supported when the resource path identifies a collection of records.
&lt;br&gt;
&lt;/p&gt;&lt;br&gt;&lt;p&gt;&lt;b&gt;Usage:&lt;/b&gt;
&lt;ul&gt;
&lt;li&gt;/groups?$count=true&lt;/&gt;
&lt;/ul&gt;
&lt;/p&gt;</sci:help>
						<sci:legalval selected="true">False</sci:legalval>
						<sci:legalval>True</sci:legalval>
					</sci:arg>
					<sci:arg name="Distinct" type="StringType" required="false" visibility="visible" multi="false">
						<sci:metaproplist>
							<sci:mpropval name="SCI_PromotedFrom" type="StringType">
								<sci:value>Distinct</sci:value>
							</sci:mpropval>
						</sci:metaproplist>
						<sci:help>&lt;p&gt;The &lt;b&gt;distinct&lt;/b&gt; query option can be used to get the list of unique values from a resource. It takes a comma-delimited list of properties to get distinct values for. 
The results are sorted in ascending order.
&lt;br&gt;
NOTE: Using &lt;b&gt;distinct&lt;/b&gt; with nested properties is currently not supported. Using &lt;b&gt;expand&lt;/b&gt; and/or &lt;b&gt;include&lt;/b&gt; with &lt;b&gt;distinct&lt;/b&gt; is not allowed. An HTTP 422 error will be returned for both of these cases.
&lt;br&gt;
&lt;/p&gt;&lt;br&gt;&lt;p&gt;&lt;b&gt;Usage:&lt;/b&gt;
&lt;ul&gt;
&lt;li&gt;/equipmenttypes?$distinct=manufacturer&lt;/li&gt;
&lt;/ul&gt;
&lt;/p&gt;</sci:help>
					</sci:arg>
					<sci:arg name="Filter" type="StringType" required="false" visibility="visible" multi="false">
						<sci:metaproplist>
							<sci:mpropval name="SCI_PromotedFrom" type="StringType">
								<sci:value>Filter</sci:value>
							</sci:mpropval>
						</sci:metaproplist>
						<sci:help>&lt;p&gt;A list of filters to use in an OR fashion to filter the entity return.

&lt;table&gt;
&lt;tr&gt;&lt;td&gt;Operator&lt;/td&gt;&lt;td&gt;Description&lt;/td&gt;&lt;td&gt;Example&lt;/td&gt;&lt;tr&gt;
&lt;tr&gt;&lt;td&gt;eq&lt;/td&gt;&lt;td&gt;Equal&lt;/td&gt;&lt;td&gt;name eq &apos;mygroup&apos;&lt;/td&gt;&lt;tr&gt;
&lt;tr&gt;&lt;td&gt;ne&lt;/td&gt;&lt;td&gt;Not Equal&lt;/td&gt;&lt;td&gt;name ne &apos;mygroup&apos;&lt;/td&gt;&lt;tr&gt;
&lt;tr&gt;&lt;td&gt;gt&lt;/td&gt;&lt;td&gt;Greater than&lt;/td&gt;&lt;td&gt;lastUpdated gt &apos;2014-12-11T16:50:09Z&apos;&lt;/td&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;td&gt;ge&lt;/td&gt;&lt;td&gt;Greater than or equal&lt;/td&gt;&lt;td&gt;lastUpdated ge &apos;2014-12-11T16:50:09Z&apos;&lt;/td&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;td&gt;lt&lt;/td&gt;&lt;td&gt;Less than&lt;/td&gt;&lt;td&gt;lastUpdated lt &apos;2014-12-11T16:50:09Z&apos;&lt;/td&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;td&gt;le&lt;/td&gt;&lt;td&gt;Less then or equal&lt;/td&gt;&lt;td&gt;lastUpdated le &apos;2014-12-11T16:50:09Z&apos;&lt;/td&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;td&gt;and&lt;/td&gt;&lt;td&gt;Logical and&lt;/td&gt;&lt;td&gt;name ne &apos;mygroup&apos; and isRole eq false&lt;/td&gt;&lt;tr&gt;
&lt;tr&gt;&lt;td&gt;or&lt;/td&gt;&lt;td&gt;Logical or&lt;/td&gt;&lt;td&gt;application/name eq &apos;hub&apos; or application/name eq &apos;insight&apos;&lt;/td&gt;&lt;/tr&gt;
&lt;/table&gt;
In addition to operators, a set of functions are also defined to use with the filter query string option. 
A filter expression can have both operators and functions used with logical operators. 
The functions currently supported are shown in the following table. 
&lt;table&gt;
&lt;tr&gt;&lt;td&gt;contains&lt;/td&gt;&lt;td&gt;contains(name, &apos;student&apos;)&lt;/td&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;td&gt;startswith&lt;/td&gt;&lt;td&gt;startswith(name, &apos;admin&apos;)&lt;/td&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;td&gt;endswith&lt;/td&gt;&lt;td&gt;endswith(application/name, &apos;hub&apos;)&lt;/td&gt;&lt;/tr&gt;
&lt;/table&gt;
These filters are all case-insensitive.
&lt;/p&gt;</sci:help>
					</sci:arg>
					<sci:arg name="Order By" type="StringType" required="false" visibility="visible" multi="false">
						<sci:metaproplist>
							<sci:mpropval name="SCI_PromotedFrom" type="StringType">
								<sci:value>Order By</sci:value>
							</sci:mpropval>
						</sci:metaproplist>
						<sci:help>&lt;p&gt;
The &lt;b&gt;orderby&lt;/b&gt; query option specifies an expression for determining what values are used to order the collection of resources. 
This query option is only supported when the resource path identifies a collection of records.
&lt;br&gt;
&lt;/p&gt;&lt;br&gt;&lt;p&gt;&lt;b&gt;Usage:&lt;/b&gt;
&lt;ul&gt;
&lt;li&gt;/groups?$orderby=name,description&lt;/li&gt;
&lt;/ul&gt;
&lt;/p&gt;</sci:help>
					</sci:arg>
					<sci:arg name="Page" type="StringType" required="false" visibility="visible" multi="false">
						<sci:metaproplist>
							<sci:mpropval name="SCI_PromotedFrom" type="StringType">
								<sci:value>Page</sci:value>
							</sci:mpropval>
						</sci:metaproplist>
						<sci:help>&lt;p&gt;
The &lt;b&gt;page&lt;/b&gt; query option specifies the id of a record to search for (and the &lt;b&gt;top&lt;/b&gt; &apos;page size&apos; parameter must also be specified). 
The call queries the database (honoring &lt;b&gt;filter&lt;/b&gt;, &lt;b&gt;orderby&lt;/b&gt;, &lt;b&gt;search&lt;/b&gt;) for the record and returns the page number and the records for the page that includes the record. 
The return format is as an object with the page property and a nested results list just like for &lt;b&gt;count&lt;/b&gt;.
&lt;br&gt;
Note: If the $count=true parameter is also included, the count property will be returned as well as page&lt;br&gt;
Note: a 404 is returned if the id cannot be found (subject to any $filter etc. restrictions that are also in effect)
&lt;br&gt;
&lt;/p&gt;&lt;br&gt;&lt;p&gt;&lt;b&gt;Usage:&lt;/b&gt;
&lt;ul&gt;
&lt;li&gt;/units?$page=e29251b7-66c7-40ca-9e9a-4641f303ac58&amp;$top=10&lt;/li&gt;
&lt;/ul&gt;
&lt;/p&gt;</sci:help>
					</sci:arg>
					<sci:arg name="Search" type="StringType" required="false" visibility="visible" multi="false">
						<sci:metaproplist>
							<sci:mpropval name="SCI_PromotedFrom" type="StringType">
								<sci:value>Search</sci:value>
							</sci:mpropval>
						</sci:metaproplist>
						<sci:help>&lt;p&gt;
This &lt;b&gt;search&lt;/b&gt; query option is only supported when the resource path identifies a collection of records. This query option can be used to search text for multiple properties. 
This is equivalent to using $filter=contains(searchField, &apos;value&apos;) [or contains(searchField2, &apos;value&apos;) ...]. This option can also be used in conjunction with the &lt;b&gt;filter&lt;/b&gt; query option. 
The search fields that are used in the filter expression are listed in a static searchFields property defined on the domain class.
&lt;br&gt;
&lt;/p&gt;&lt;br&gt;&lt;p&gt;&lt;b&gt;Usage:&lt;/b&gt;
&lt;ul&gt;
&lt;li&gt;/groups?$search=texttofind&lt;/li&gt;
&lt;/ul&gt;
&lt;/p&gt;</sci:help>
					</sci:arg>
					<sci:arg name="Show" type="StringType" required="false" visibility="visible" multi="false">
						<sci:metaproplist>
							<sci:mpropval name="SCI_PromotedFrom" type="StringType">
								<sci:value>Show</sci:value>
							</sci:mpropval>
						</sci:metaproplist>
						<sci:help>&lt;p&gt;
The &lt;b&gt;show&lt;/b&gt; query option is used to show additional records that are typically hidden such as deleted records. 
&lt;b&gt;show&lt;/b&gt; takes a comma-delimited list of options and currently &apos;deleted&apos; and &apos;allIgnorePermissions&apos; are supported. Specifying $show=deleted will include deleted entities in the collection. 
Specifying $show=allIgnorePermissions will include all records ignoring any permissions assigned to the entity (i.e. links, settingpages) for an admin user. 
If a non-admin user sends $show=allIgnorePermissions in the request, it will be ignored.
&lt;br&gt;
&lt;/p&gt;&lt;br&gt;&lt;p&gt;&lt;b&gt;Usage:&lt;/b&gt;
&lt;ul&gt;
&lt;li&gt;/groups?$show=deleted&lt;/li&gt;
&lt;/ul&gt;
&lt;/p&gt;</sci:help>
					</sci:arg>
					<sci:arg name="Skip" type="LongType" required="false" visibility="visible" multi="false">
						<sci:metaproplist>
							<sci:mpropval name="SCI_PromotedFrom" type="StringType">
								<sci:value>Skip</sci:value>
							</sci:mpropval>
							<sci:propval name="SCI_PromotionRenameRule">UsingParent</sci:propval>
						</sci:metaproplist>
						<sci:help>&lt;p&gt;
The &lt;b&gt;skip&lt;/b&gt; query option is equivalent to the offset paging parameter or &apos;start&apos; in ExtJS which will return the collection of entries skipping the first N records where $skip=N
&lt;br&gt;
&lt;/p&gt;&lt;br&gt;&lt;p&gt;&lt;b&gt;Usage:&lt;/b&gt;
&lt;ul&gt;
&lt;li&gt;/groups?$skip=2&lt;/li&gt;
&lt;/ul&gt;
&lt;/p&gt;</sci:help>
						<sci:value>0</sci:value>
					</sci:arg>
					<sci:arg name="Top" type="LongType" required="false" visibility="visible" multi="false">
						<sci:metaproplist>
							<sci:mpropval name="SCI_PromotedFrom" type="StringType">
								<sci:value>Top</sci:value>
							</sci:mpropval>
							<sci:propval name="SCI_PromotionRenameRule">UsingParent</sci:propval>
						</sci:metaproplist>
						<sci:help>&lt;p&gt;
The &lt;b&gt;top&lt;/b&gt; query option is equivalent to &apos;max&apos; or &apos;limit&apos; in ExtJS which will return only the number of records you specify for &lt;b&gt;top&lt;/b&gt;.
&lt;br&gt;
&lt;/p&gt;&lt;br&gt;&lt;p&gt;&lt;b&gt;Usage:&lt;/b&gt;
&lt;ul&gt;
&lt;li&gt;/groups?$top=3&lt;/li&gt;
&lt;/ul&gt;
&lt;/p&gt;</sci:help>
						<sci:value>0</sci:value>
					</sci:arg>
					<sci:arg name="Version" type="LongType" required="false" visibility="visible" multi="false">
						<sci:metaproplist>
							<sci:mpropval name="SCI_PromotedFrom" type="StringType">
								<sci:value>Version</sci:value>
							</sci:mpropval>
						</sci:metaproplist>
						<sci:help>&lt;p&gt;
The &lt;b&gt;version&lt;/b&gt; query option can be used to control which version of the resource entries is returned in the collection. 
This query option is more useful when used with the &lt;b&gt;history&lt;/b&gt; facet. See the facet.md file for more information about the &lt;b&gt;history&lt;/b&gt; facet.
&lt;br&gt;
&lt;/p&gt;&lt;br&gt;&lt;p&gt;&lt;b&gt;Usage:&lt;/b&gt;
&lt;ul&gt;
&lt;li&gt;/groups?$version=2&lt;/li&gt;
&lt;/ul&gt;
&lt;/p&gt;</sci:help>
					</sci:arg>
					<sci:arg name="Page Size" type="LongType" required="true" visibility="visible" multi="false">
						<sci:metaproplist>
							<sci:mpropval name="SCI_PromotedFrom" type="StringType">
								<sci:value>Page Size</sci:value>
							</sci:mpropval>
						</sci:metaproplist>
						<sci:help>&lt;p&gt;
The &lt;b&gt;Page Size&lt;/b&gt; parameter can be used to control the number of records that will be returned in a single page. This value cannot exceed the Maximum REST Call Results setting on the Foundation Hub server (Default 5000).
&lt;/p&gt;</sci:help>
						<sci:validscript>Parameter() &gt; 0</sci:validscript>
						<sci:value>1000</sci:value>
					</sci:arg>
					<sci:arg name="Distinct Modifiers" type="StringType" required="false" visibility="visible" multi="false" expanded="true">
						<sci:metaproplist>
							<sci:mpropval name="SCI_PromotedFrom" type="StringType">
								<sci:value>Distinct Modifiers</sci:value>
							</sci:mpropval>
							<sci:propval name="SCI_PromotionRenameRule">UsingParent</sci:propval>
						</sci:metaproplist>
						<sci:help>
&lt;p&gt;Modifies data records from the Hub using the set of APIs. The modifiers are detailed in the following link:&lt;/p&gt;
&lt;p&gt;&lt;a href=&quot;javascript:DoLink(&apos;https://lw5-ttr1-bio.dsone.3ds.com:8443/foundation/hub/doc/odata&apos;)&quot;&gt;OData Specifications&lt;/a&gt;&lt;/p&gt;
</sci:help>
						<sci:member>Expand</sci:member>
						<sci:member>Include</sci:member>
					</sci:arg>
					<sci:arg name="Expand" type="StringType" required="false" visibility="visible" multi="true">
						<sci:metaproplist>
							<sci:mpropval name="SCI_PromotedFrom" type="StringType">
								<sci:value>Expand</sci:value>
							</sci:mpropval>
						</sci:metaproplist>
						<sci:help>&lt;p&gt;
The &lt;b&gt;expand&lt;/b&gt; query option is used to include associated related entries inline for each entry in the collection. 
Facets can also be expanded for each entry in the collection. See the facet.md file for more information on facets. 
Since expanded properties are not properties of the domain class but rather associations, they cannot be used in &lt;b&gt;filter&lt;/b&gt; or &lt;b&gt;orderby&lt;/b&gt; expressions.
&lt;br&gt;
NOTE: To be able to use the &lt;b&gt;expand&lt;/b&gt; option for including associated entries, the resource service should have all the 
association classes listed in the static parents DSL as shown below. Parents which have an associationClass in the DSL will be included inline for each returned record. 
If only a subset of child services are allowed to be expanded, then the service needs to explicitly define the list of expandables using the static expandable property. 
See the RestfulApiPlugin&apos;s README.md file for the description of the Parents DSL and the service&apos;s expandable configuration static.
&lt;br&gt;
&lt;/p&gt;&lt;br&gt;&lt;p&gt;&lt;b&gt;Usage:&lt;/b&gt;
&lt;ul&gt;
&lt;li&gt;/groups?$expand=users,permissions&lt;/li&gt;
&lt;li&gt;/groups?$expand=users,permissions,$count&lt;/li&gt;
&lt;li&gt;/groups?$expand=*&lt;/li&gt;
&lt;li&gt;/groups?$expand=*,$count&lt;/li&gt;
&lt;/ul&gt;
&lt;/p&gt;</sci:help>
						<sci:legalvalscript>endpoints := Parameter(&apos;Endpoints&apos;);
Expand(&apos;,&apos;,EndPoints);
entity := Parameter(&apos;Entity&apos;);
Resize(lvals,0);
ForEach endpoint in endpoints loop
if endpoint rlike &apos;^/&apos;.entity then
child := RMatch(endpoint,&apos;\/\{id\}\/([a-zA-Z]+)&apos;);
if child ne &apos;&apos; then
if NOT Contains(lvals,child[2]) then
Append(lvals,child[2]);
end if;
end if;
end if;
end loop;
Append(lvals,&apos;$properties&apos;);
Append(lvals,&apos;*&apos;);
SetLegalValues(lvals);</sci:legalvalscript>
						<sci:value>tasks</sci:value>
						<sci:value>$properties</sci:value>
					</sci:arg>
					<sci:arg name="Include" type="StringType" required="false" visibility="visible" multi="false">
						<sci:metaproplist>
							<sci:mpropval name="SCI_PromotedFrom" type="StringType">
								<sci:value>Include</sci:value>
							</sci:mpropval>
						</sci:metaproplist>
						<sci:help>&lt;p&gt;
Similarly to &lt;b&gt;expand&lt;/b&gt;, the &lt;b&gt;include&lt;/b&gt; option can be used to include properties of the domain class which are not normally included in the result data. 
This requires the static includable to be defined on the domain class. This option can also be used to change the marshalling of the result data by prefixing the value with &apos;$&apos;.
&lt;br&gt;
&lt;/p&gt;&lt;br&gt;&lt;p&gt;&lt;b&gt;Usage:&lt;/b&gt;
&lt;ul&gt;
&lt;li&gt;/groups?$include=prop1&lt;/li&gt;
&lt;li&gt;/groups?$include=$summary&lt;/li&gt;
&lt;/ul&gt;
&lt;/p&gt;</sci:help>
						<sci:value>version</sci:value>
					</sci:arg>
					<sci:arg name="Other" type="GroupType" required="false" visibility="visible" multi="false">
						<sci:metaproplist>
							<sci:propval name="SCI_PromotionRenameRule">UsingParent</sci:propval>
							<sci:mpropval name="SCI_PromotedFrom" type="StringType">
								<sci:value>Other</sci:value>
							</sci:mpropval>
						</sci:metaproplist>
						<sci:help>A parameter created by setparam()</sci:help>
						<sci:member>Fail Empty Records</sci:member>
						<sci:member>Output Collection</sci:member>
						<sci:member>On Foundation Hub Server Error</sci:member>
						<sci:member>Maximum Response Size</sci:member>
						<sci:member>Timeout</sci:member>
					</sci:arg>
					<sci:arg name="Fail Empty Records" type="BoolType" required="true" visibility="visible" multi="false">
						<sci:metaproplist>
							<sci:mpropval name="SCI_PromotedFrom" type="StringType">
								<sci:value>Fail Empty Records</sci:value>
							</sci:mpropval>
						</sci:metaproplist>
						<sci:help>&lt;p&gt; Outputs query as a collection of results in contrast to single results as single records. Default is false.</sci:help>
						<sci:value>False</sci:value>
					</sci:arg>
					<sci:arg name="Output Collection" type="BoolType" required="true" visibility="visible" multi="false">
						<sci:metaproplist>
							<sci:mpropval name="SCI_PromotedFrom" type="StringType">
								<sci:value>Output Collection</sci:value>
							</sci:mpropval>
						</sci:metaproplist>
						<sci:help>&lt;p&gt; Outputs query as a collection of results in contrast to single results as single records. Default is false.</sci:help>
						<sci:value>False</sci:value>
					</sci:arg>
					<sci:arg name="On Foundation Hub Server Error" type="StringType" required="false" visibility="visible" multi="false">
						<sci:metaproplist>
							<sci:mpropval name="SCI_PromotedFrom" type="StringType">
								<sci:value>On Foundation Hub Server Error</sci:value>
								<sci:value>On Foundation Hub Server Error</sci:value>
							</sci:mpropval>
							<sci:propval name="SCI_PromotionRenameRule">UsingParent</sci:propval>
						</sci:metaproplist>
						<sci:help>On Foundation Hub Server Error

If set to True, responses from the server with an http error code (400 and higher) will be evaluated by the component and create a component error.
If set to False, error responses will be returned on the Fail Port of the component.
Type and Value:
Parameter Type: StringType
Send Data out the Fail Port

Metadata:
SCI_PromotedFrom:   Evaluate Server Errors
SCI_PromotionRenameRule:   UsingParent</sci:help>
						<sci:legalval>Send Data out the Pass Port</sci:legalval>
						<sci:legalval selected="true">Send Data out the Fail Port</sci:legalval>
						<sci:legalval>Halt Protocol Execution</sci:legalval>
					</sci:arg>
					<sci:arg name="Maximum Response Size" type="StringType" required="false" visibility="visible" multi="false">
						<sci:metaproplist>
							<sci:mpropval name="SCI_PromotedFrom" type="StringType">
								<sci:value>Maximum Response Size</sci:value>
								<sci:value>Maximum Response Size</sci:value>
							</sci:mpropval>
							<sci:propval name="SCI_PromotionRenameRule">UsingParent</sci:propval>
						</sci:metaproplist>
						<sci:help>Maximum Response Size

The maximum amount of data in bytes to download from the server. The reponse data is truncated once the limit has been reached. If the parameter is blank, the limit is the default value of 64 MB.
Type and Value:
Parameter Type: LongType
64000000

Metadata:
SCI_PromotedFrom:   Maximum Response Size
SCI_PromotionRenameRule:   UsingParent</sci:help>
						<sci:value>64000000</sci:value>
					</sci:arg>
					<sci:arg name="Timeout" type="StringType" required="false" visibility="visible" multi="false">
						<sci:metaproplist>
							<sci:mpropval name="SCI_PromotedFrom" type="StringType">
								<sci:value>Timeout</sci:value>
								<sci:value>Timeout</sci:value>
							</sci:mpropval>
							<sci:propval name="SCI_PromotionRenameRule">UsingParent</sci:propval>
						</sci:metaproplist>
						<sci:help>Timeout

The time in seconds to wait for a response from the server.
Type and Value:
Parameter Type: LongType
30

Metadata:
SCI_PromotedFrom:   Timeout
SCI_PromotionRenameRule:   UsingParent</sci:help>
						<sci:value>30</sci:value>
					</sci:arg>
					<sci:arg name="RunToCompletion" type="StringType" required="false" visibility="visible" multi="false" uimpl="false">
						<sci:help>When &lt;i&gt;RunToCompletion&lt;/i&gt; is set to &quot;True - For Each Data Record&quot;, the subprotocol is re-initialized and executed in its entirety for each individual data record it processes.
&lt;p&gt;
When set to &quot;True - For Each Category&quot;, the data records are divided into categories based on the value of the Categorize Using parameter and then the subprotocol is re-initialized and executed in its entirety for each category of data records. When used in conjunction with &lt;i&gt;Parallel Processing Options&lt;/i&gt;, each category of data records will be sent to the remote server as part of one single batch.</sci:help>
						<sci:member>RunToCompletion Categorize Using</sci:member>
						<sci:legalval selected="true">False</sci:legalval>
						<sci:legalval>True - For Each Data Record</sci:legalval>
						<sci:legalval>True - For Each Category</sci:legalval>
					</sci:arg>
					<sci:arg name="RunToCompletion Categorize Using" type="StringType" required="false" visibility="visible" multi="false" uimpl="false">
						<sci:help>Required when RunToCompletion is set to &lt;i&gt;True - For Each Category&lt;/i&gt;, this parameter specifies the property or properties used to define the categories.</sci:help>
						<sci:validscript>SetInvalidDetails(&apos;This parameter is required when RunToCompletion is set to True - For Each Category&apos;);
Parameter() ne &apos;&apos;;</sci:validscript>
						<sci:enabledscript>SetDisabledDetails(&apos;To Enable, Set RunToCompletion to True - For Each Category&apos;);
Parameter(&apos;RunToCompletion&apos;) eq &apos;True - For Each Category&apos;;</sci:enabledscript>
					</sci:arg>
					<sci:arg name="Parallel Processing Options" type="BoolType" required="false" visibility="visible" multi="false" uimpl="false">
						<sci:help>&lt;p&gt;
When set to True, this set of options allow the subprotocol to execute in parallel on one or more independent Pipeline Pilot servers, running local or remote.  Additional parameters control the number of data records to send in each process batch, the list of Pipeline Pilot servers to use, the number of protocol processes that can be executed on each server, and whether to preserve the order of the processed data records.
&lt;/p&gt;&lt;p&gt;
Use this option judiciously, since it will not increase throughput in all circumstances. In general, it will yield improved performance when the parallelization benefits outweigh the data transfer overhead for the specified batch size.  As a rough guide, performance can be improved when each individual batch requires at least 10 seconds to execute, although this can be affected by the size of each data record.
&lt;/p&gt;&lt;p&gt;
When running the protocol with debugging, the subprotocol will provide debugging messages to detail each of the various steps of execution.  Also, components located within the parallel subprotocol will display their debugging messages as well.
&lt;/p&gt;&lt;p&gt;
For more information on the parallel subprotocol options, see &lt;a href=&quot;javascript:DoLink(&apos;scihelpdocs/user/subprots/subprot_parallel_processing.htm&apos;)&quot;&gt;Parallel Processing Subprotocols&lt;/a&gt;.
&lt;/p&gt;
</sci:help>
						<sci:member>Parallel Processing Options Batch Size</sci:member>
						<sci:member>Parallel Processing Options Server</sci:member>
						<sci:member>Parallel Processing Options Preserve Order</sci:member>
						<sci:legalval>True</sci:legalval>
						<sci:legalval selected="true">False</sci:legalval>
					</sci:arg>
					<sci:arg name="Parallel Processing Options Batch Size" type="LongType" required="true" visibility="visible" multi="false" uimpl="false">
						<sci:help>&lt;p&gt;The number of records to send to the remote server(s) for each subprotocol execution.  In general, performance is optimized when the amount of time required to process each batch is at least 10 seconds (note that this can vary depending on the characteristics of the remote server&apos;s hardware).  Use a batch size of -1 to pass all data in a single batch.&lt;/p&gt;
&lt;p&gt;When &lt;i&gt;RunToCompletion&lt;/i&gt; is set to &quot;True - for each category&quot;, the batch sizes will be determined by the number of records in each individual category.  Therefore, the &lt;i&gt;Batch Size&lt;/i&gt; parameter is not applicable.</sci:help>
						<sci:enabledscript>#parallel := Parameter(&apos;Parallel Processing Options&apos;);
if (not #parallel) then
	SetDisabledDetails(&quot;This parameter is only applicable if &apos;Parallel Processing Options&apos; is &apos;True&apos;&quot;);
end if;
#parallel;</sci:enabledscript>
					</sci:arg>
					<sci:arg name="Parallel Processing Options Server" type="StringType" required="false" visibility="visible" multi="true" expanded="true" legalvalsenforced="false" uimpl="false">
						<sci:help>&lt;p&gt;
Comma separated list of Pipeline Pilot servers on which to execute the parallel subprotocol.  The server names should be in the same format as the Pipeline Pilot Client&apos;s change server dialog (server-name:port-number).
&lt;/p&gt;&lt;p&gt;
Specifying &lt;b&gt;localhost&lt;/b&gt; as a server will cause the subprotocol to use its own Pipeline Pilot server.  This can be helpful on multi-CPU/multi-core systems (where the subprotocol jobs are spawned on the same machine) and Pipeline Pilot Linux clusters (where &apos;localhost&apos; requests spawning the subprotocol jobs on the same cluster).
&lt;/p&gt;</sci:help>
						<sci:member>Parallel Processing Options Server Processes</sci:member>
						<sci:member>Parallel Processing Options Server Run On Grid</sci:member>
						<sci:validscript>SetInvalidDetails(&apos;This parameter is required.&apos;);
Parameter() ne &apos;&apos;;</sci:validscript>
						<sci:enabledscript>SetDisabledDetails(&quot;This parameter is only applicable if &apos;Parallel Processing Options&apos; is &apos;True&apos;&quot;);
Parameter(&apos;Parallel Processing Options&apos;);</sci:enabledscript>
					</sci:arg>
					<sci:arg name="Parallel Processing Options Server Processes" type="StringType" required="false" visibility="visible" multi="false" uimpl="false">
						<sci:help>Comma separated list of maximum number of batches that can be simultaneously executed on each remote server.  The number of entries in this parameter must equal the number of servers. If &apos;*&apos; is specified as the number of processes, then that server will only launch as many batches as the administrator of the remote server has permitted.</sci:help>
						<sci:validscript>/* Server Processes must have the same number of comma separated entries as the Server parameter and must have a value*/
#processes := parameter();
expand(&apos;,&apos;, #processes);
#servers := parameter(&apos;Parallel Processing Options Server&apos;);
expand(&apos;,&apos;, #servers);

if (numvalues(#processes) == 0) then
	SetInvalidDetails(&apos;This parameter is required.&apos;);
else
	SetInvalidDetails(&apos;The number of server processes (&apos; . numvalues(#processes) . &apos;) must equal the number of servers (&apos; . numvalues(#servers) . &apos;).&apos;);
end if;
numvalues(#processes) &gt; 0 and numvalues(#processes) == numvalues(#servers);</sci:validscript>
						<sci:enabledscript>SetDisabledDetails(&quot;This parameter is only applicable if &apos;Parallel Processing Options&apos; is &apos;True&apos;&quot;);
Parameter(&apos;Parallel Processing Options&apos;);</sci:enabledscript>
					</sci:arg>
					<sci:arg name="Parallel Processing Options Server Run On Grid" type="BoolType" required="false" visibility="visible" multi="false" uimpl="false">
						<sci:help>Run subprotocol on grid engine if available.</sci:help>
						<sci:member>Parallel Processing Options Server Run On Grid Queue Name</sci:member>
						<sci:member>Parallel Processing Options Server Run On Grid Grid Options</sci:member>
						<sci:enabledscript>parameter(&apos;Parallel Processing Options&apos;);</sci:enabledscript>
						<sci:legalval selected="true">True</sci:legalval>
						<sci:legalval>False</sci:legalval>
					</sci:arg>
					<sci:arg name="Parallel Processing Options Server Run On Grid Queue Name" type="StringType" required="false" visibility="visible" multi="false" legalvalsenforced="false" uimpl="false">
						<sci:help>Select the queue name on the grid to submit jobs to. Leave blank to use default queue name.</sci:help>
						<sci:enabledscript>parameter(&apos;Parallel Processing Options Server Run On Grid&apos;);</sci:enabledscript>
					</sci:arg>
					<sci:arg name="Parallel Processing Options Server Run On Grid Grid Options" type="StringType" required="false" visibility="visible" multi="false" uimpl="false">
						<sci:help>Use this to specify grid engine specific command line parameters to the job submission command. Leave blank to use defaults.</sci:help>
						<sci:enabledscript>parameter(&apos;Parallel Processing Options Server Run On Grid&apos;);</sci:enabledscript>
					</sci:arg>
					<sci:arg name="Parallel Processing Options Preserve Order" type="BoolType" required="false" visibility="visible" multi="false" uimpl="false">
						<sci:help>Whether to preserve the order of the data as it enters and leaves the remote subprotocol.</sci:help>
						<sci:enabledscript>SetDisabledDetails(&quot;This parameter is only applicable if &apos;Parallel Processing Options&apos; is &apos;True&apos;&quot;);
Parameter(&apos;Parallel Processing Options&apos;);</sci:enabledscript>
						<sci:legalval selected="true">True</sci:legalval>
						<sci:legalval>False</sci:legalval>
					</sci:arg>
					<sci:arg name="Tempfiles" type="StringType" required="false" visibility="visible" multi="false" uimpl="true">
						<sci:help>&lt;p&gt;A comma delimited list of global properties, each of which will automatically hold the name of a file in the job&apos;s temporary folder, whose name is guaranteed to be unique.&lt;p/&gt;For each global name, an additional global is created (with the suffix &lt;i&gt;_Filename&lt;/i&gt;) that hold just the leaf file name of the temporary file.&lt;/p&gt;</sci:help>
					</sci:arg>
					<sci:arg name="DeclareLocal" type="StringType" required="false" visibility="visible" multi="false" uimpl="true">
						<sci:help>&lt;p&gt;Lists a set of properties (without the @) to create on the global property list for this subprotocol. Such properties can only be accessed within the scope of this subprotocol and its descendent subprotocols.&lt;p/&gt;Any global property not declared in this way is created on the top level global property list and is accessible from all protocols, but may collide with another property of the same name.&lt;/p&gt;&lt;p&gt;Scoping global properties to the subprotocol where they are used is highly recommended.&lt;/p&gt;</sci:help>
					</sci:arg>
					<sci:arg name="ComponentAttributes" type="StringType" required="false" visibility="hidden" multi="true">
						<sci:help>Component Attributes</sci:help>
						<sci:legalval>ComponentTakesInput</sci:legalval>
